# Shell scripts must have LF endings to execute inside Linux/Docker containers.
# Without this, Git on Windows checks out files with CRLF, breaking shebangs.
*.sh        text eol=lf

# Other files that run or are parsed inside Linux containers
Dockerfile* text eol=lf
*.conf      text eol=lf
*.ini       text eol=lf
*.py        text eol=lf

# Standard text files — normalize but don't force LF (editors handle these)
*.md        text
*.json      text
*.yml       text
*.yaml      text
*.txt       text
*.env*      text
*.html      text
