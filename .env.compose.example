# Non-secret Docker Compose configuration.
# Copy to .env.compose and pass it with: docker compose --env-file .env.compose ...
#
# Member credentials (IBKR account ID, IBKR username, IBKR password, VNC
# password) are managed via the secrets container UI at http://localhost:8001
# — do NOT add them here. setup_docker.sh opens the UI on first run.
#
# ─────────────────────────────────────────────────────────────────────────────
# THIS FILE IS INSTALL-TIME ONLY.
#
# It configures how the containers are WIRED to this host — which host ports to
# publish and which gateway image tag to build. That is all. Everything about
# how the fund BEHAVES is owned by the app after install:
#
#   • Dashboard → Settings   writes /data/settings.json (fund parameters,
#                            trading mode, auto-restart time, timezone, …)
#   • /data/gw_trading_mode  durable live/paper switch, read by every container
#   • /data/gw_auto_restart_time  durable gateway restart time
#
# Those live in the yrvi_data volume and survive upgrades. This file does not:
# an upgrade resets it to the committed defaults below. That is exactly why it
# must not be authoritative — a stale value here silently shadowing the app is
# how RELOGIN_AFTER_TWOFA_TIMEOUT=no survived on every box and turned a routine
# gateway wedge into a 26-hour outage on 2026-07-17.
#
# Older installs still have extra keys in their own .env.compose (IBKR_PORT,
# READ_ONLY_API, the TWOFA_* family, …). They are harmless: the app no longer
# reads them. The entrypoint logs any it finds, so you can confirm they are
# being ignored rather than having to reason about this file.
# ─────────────────────────────────────────────────────────────────────────────

IB_GATEWAY_TAG=latest

# First-boot seed only. After install the durable /data/gw_trading_mode file
# (written by Dashboard → Settings) is the source of truth.
TRADING_MODE=paper
TIME_ZONE=America/Los_Angeles

# Local host ports. Change only if something else on this host already uses one.
# Keep these bound to 127.0.0.1 in docker-compose.yml.
IB_GATEWAY_LIVE_PORT=4001
IB_GATEWAY_PAPER_PORT=4002
IB_GATEWAY_VNC_PORT=5900
YRVI_API_PORT=8000
YRVI_WEB_PORT=3000
VIEW_GATEWAY_PORT=6080
