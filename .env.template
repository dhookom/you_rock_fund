# Interactive Brokers connection
IBKR_HOST=127.0.0.1
IBKR_PORT=4002
IBKR_CLIENT_ID=1
ACCOUNT=YOUR_IBKR_ACCOUNT_ID
IBKR_USERNAME=your_ibkr_username
