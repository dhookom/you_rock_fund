# Non-secret Docker Compose configuration.
# Copy to .env.compose and pass it with: docker compose --env-file .env.compose ...
#
# Member credentials (IBKR account ID, IBKR username, IBKR password, VNC
# password) are managed via the secrets container UI at http://localhost:8001
# — do NOT add them here. setup_docker.sh opens the UI on first run.

IB_GATEWAY_TAG=latest
TRADING_MODE=paper
TIME_ZONE=America/Los_Angeles

IBKR_PORT=4004
IBKR_CLIENT_ID=1
RENDER_URL=https://yourockclub-ledger-sync.onrender.com/api/targets/csp

# Local host ports. Keep these bound to 127.0.0.1 in docker-compose.yml.
IB_GATEWAY_LIVE_PORT=4001
IB_GATEWAY_PAPER_PORT=4002
IB_GATEWAY_VNC_PORT=5900
YRVI_API_PORT=8000
YRVI_WEB_PORT=3000
# View Gateway (opt-in browser VNC viewer, "viewer" profile). See docs/view-gateway.md.
VIEW_GATEWAY_PORT=6080

# API permissions. This app places orders, so READ_ONLY_API must be no.
READ_ONLY_API=no
TWS_ACCEPT_INCOMING=accept
ALLOW_BLIND_TRADING=no

# 2FA / recovery options
TWOFA_TIMEOUT_ACTION=exit
RELOGIN_AFTER_TWOFA_TIMEOUT=no
TWOFA_EXIT_INTERVAL=60
AUTO_RESTART_TIME=11:59 PM
EXISTING_SESSION_DETECTED_ACTION=primary
