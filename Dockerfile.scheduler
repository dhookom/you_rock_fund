FROM python:3.13-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

COPY requirements.txt .
RUN pip install --upgrade pip \
    && pip install -r requirements.txt

COPY . .
COPY docker/entrypoint-secrets.sh /usr/local/bin/yrvi-entrypoint
RUN sed -i 's/\r$//' /usr/local/bin/yrvi-entrypoint \
    && chmod +x /usr/local/bin/yrvi-entrypoint

ENTRYPOINT ["yrvi-entrypoint"]
CMD ["python", "scheduler.py"]
